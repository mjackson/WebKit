+    MarkedBlock& block = handle->block();
+    SnapRec rec { };
+    rec.cycle = s_cycle;
+    rec.block = &block;
+    bool marksStale = block.areMarksStale(markingVersion);
+    bool naStale = block.isNewlyAllocatedStale();
+    rec.marksStale = marksStale;
+    rec.naStale = naStale;
+    rec.cellSize = (uint32_t)handle->cellSize();
+    char* base = (char*)&block;
+    char* begin = (char*)handle->start();
+    char* end = (char*)handle->end();
