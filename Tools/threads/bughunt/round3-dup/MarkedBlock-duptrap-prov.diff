+            fprintf(f, "\n");
+        }
+    }
+    if (s_sweeps) {
+        for (auto& r : *s_sweeps) {
+            fprintf(f, "SWEEP seq=%llu tid=%llu block=%p toFL=%u empty=%u marks=%u na=%u ctx=%s\n",
