+    Locker locker { s_provLock };
+    char defaultPath[128];
+    snprintf(defaultPath, sizeof(defaultPath), "/tmp/bughunt-prov-%d.log", getpid());
+    const char* path = getenv("BUGHUNT_PROV_OUT");
+    FILE* f = fopen(path ? path : defaultPath, "w");
+    if (!f)
+        return;
+    if (s_snaps) {
+        for (auto& r : *s_snaps) {
