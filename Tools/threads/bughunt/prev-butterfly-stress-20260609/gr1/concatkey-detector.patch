+// BUGHUNT-GR1 (scratch instrumentation): on a flag-on cache hit, verify the
+// returned JSString really is the concatenation of the three fibers. If the
+// cache (or the cell it points at) is the corruption vehicle, this converts
+// the silent wrong-value read into a named crash at the first bad return.
+ALWAYS_INLINE void bughuntVerifyConcatKeyCacheHit(JSString* s0, JSString* s1, JSString* s2, JSString* result)
+{
+    if (!result)
+        return;
+    auto rv = result->tryGetValueWithoutGC();
+    if (!rv->impl())
+        return;
+    StringBuilder expected;
+    auto appendPart = [&](JSString* s) -> bool {
+        if (!s)
+            return true;
+        auto v = s->tryGetValueWithoutGC();
+        if (!v->impl())
+            return false;
+        expected.append(StringView(*v->impl()));
+        return true;
+    };
+    if (!appendPart(s0) || !appendPart(s1) || !appendPart(s2))
+        return;
+    String expectedString = expected.toString();
+    if (expectedString != String(rv->impl())) [[unlikely]] {
+        dataLogLn("[BUGHUNT-GR1] CONCATKEY-VEHICLE: cache hit returned wrong atom: expected=\"", expectedString, "\" got=\"", String(rv->impl()), "\"");
+        RELEASE_ASSERT_NOT_REACHED();
+    }
+}
