+        bughuntStopAwareLockAcquire(codeBlock->m_lock); // BUGHUNT H2 probe (NOT FOR LANDING)
+        GCSafeConcurrentJSLocker locker(AdoptLock, codeBlock->m_lock, globalObject->vm());
@@ tryCachePutBy locker entry (~:1238) @@
