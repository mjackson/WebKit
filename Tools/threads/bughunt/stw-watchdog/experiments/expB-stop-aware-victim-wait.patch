--- a/Source/JavaScriptCore/bytecode/Repatch.cpp
@@ after forceICFailure @@
+// BUGHUNT H2 probe (NOT FOR LANDING): stop-aware acquisition of a §7
+// CodeBlock::m_lock. On contention, release this thread's GCClient heap
+// access so the §A.3.2 conductor predicate counts the thread quiescent while
+// it waits (closing the victim-side no-poll gap), then poll tryLock. Returns
+// with the lock HELD; caller adopts it into the locker.
+static void bughuntStopAwareLockAcquire(ConcurrentJSLock& lock) WTF_IGNORES_THREAD_SAFETY_ANALYSIS
+{
+    if (lock.tryLock()) [[likely]]
+        return;
+    GCClient::Heap* client = GCClient::Heap::currentThreadClient();
+    bool released = false;
+    if (Options::useJSThreads() && client && client->hasHeapAccess()) {
+        client->releaseHeapAccess();
+        released = true;
+    }
+    while (!lock.tryLock())
+        WTF::sleep(Seconds::fromMicroseconds(50));
+    if (released)
+        client->acquireHeapAccess();
+}
